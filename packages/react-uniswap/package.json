{
  "name": "@uniswap-widget/react",
  "version": "2.1.3",
  "type": "module",
  "description": "A clean Uniswap swap widget package for easy integration",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.es.js",
        "require": "./dist/index.umd.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "uniswap",
    "swap",
    "widget",
    "defi",
    "react",
    "ethereum"
  ],
  "dependencies": {
    "@uniswap-widget/core": "workspace:*"
  },
  "peerDependencies": {
    "@reown/appkit": ">=1.4.0",
    "@reown/appkit-adapter-wagmi": ">=1.4.0",
    "@tanstack/react-query": ">=5.0.0",
    "@uniswap/sdk-core": ">=5.0.0",
    "@uniswap/v3-sdk": ">=3.0.0",
    "@uniswap/v3-core": ">=1.0.0",
    "ethers": ">=5.7.0 <7.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "wagmi": ">=2.0.0"
  },
  "devDependencies": {
    "@reown/appkit": "catalog:web3",
    "@reown/appkit-adapter-wagmi": "catalog:web3",
    "@tanstack/react-query": "catalog:web3",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:react18",
    "@types/react-dom": "catalog:react18",
    "@uniswap/sdk-core": "catalog:uniswap",
    "@uniswap/v3-core": "catalog:uniswap",
    "@uniswap/v3-sdk": "catalog:uniswap",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "ethers": "catalog:web3",
    "jsdom": "catalog:",
    "react": "catalog:react18",
    "react-dom": "catalog:react18",
    "terser": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:web3",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "wagmi": "catalog:web3"
  }
}
