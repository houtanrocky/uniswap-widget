{
  "name": "@uniswap-widget/vue",
  "version": "1.0.3",
  "type": "module",
  "description": "Vue 3 Uniswap swap widget, built on @uniswap-widget/core",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.es.js",
        "require": "./dist/index.umd.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "build:watch": "vite build --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "uniswap",
    "swap",
    "widget",
    "defi",
    "vue",
    "ethereum"
  ],
  "dependencies": {
    "@uniswap-widget/core": "workspace:*"
  },
  "peerDependencies": {
    "@reown/appkit": ">=1.4.0",
    "@reown/appkit-adapter-wagmi": ">=1.4.0",
    "@uniswap/sdk-core": ">=5.0.0",
    "@uniswap/v3-sdk": ">=3.0.0",
    "@uniswap/v3-core": ">=1.0.0",
    "@wagmi/core": ">=2.0.0",
    "ethers": ">=5.7.0 <7.0.0",
    "viem": ">=2.0.0",
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "@reown/appkit": "catalog:web3",
    "@reown/appkit-adapter-wagmi": "catalog:web3",
    "@uniswap/sdk-core": "catalog:uniswap",
    "@uniswap/v3-core": "catalog:uniswap",
    "@uniswap/v3-sdk": "catalog:uniswap",
    "@vitejs/plugin-vue": "catalog:vue",
    "@vitest/coverage-v8": "catalog:",
    "@vue/test-utils": "catalog:vue",
    "@wagmi/core": "catalog:web3",
    "ethers": "catalog:web3",
    "jsdom": "catalog:",
    "terser": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:web3",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:vue",
    "vue-tsc": "catalog:vue"
  }
}
